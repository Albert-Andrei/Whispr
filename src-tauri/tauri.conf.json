{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Whispr",
  "version": "0.1.5",
  "identifier": "com.albert.whispr",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Whispr",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": "#ffffff",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 16 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "dmg": {
        "background": "dmg/background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 154,
          "y": 136
        },
        "applicationFolderPosition": {
          "x": 378,
          "y": 136
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyQjM2OUVGOEM0RDdEQzMKUldURGZVMk03Mm16VXRJeXVYem9SbkpPZjAvcHdQUjUyWmg5MmhtZThLZVgvOTdGMTBNTEcvZjcK",
      "endpoints": [
        "https://github.com/Albert-Andrei/Whispr/releases/latest/download/latest.json"
      ]
    }
  }
}
